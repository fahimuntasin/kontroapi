NODE_ENV=development
PORT=3000

# Mode: 'cloud' (uses Supabase) or 'self-hosted' (uses local Postgres)
KONTROAPI_MODE=cloud

# Supabase (only required in cloud mode)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local Postgres (only required in self-hosted mode)
LOCAL_DB_URL=postgresql://kontroapi:kontroapi@localhost:5432/kontroapi

# Redis (used in both modes)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth (must match dashboard JWT_SECRET)
JWT_SECRET=please-change-this-to-a-32-character-or-longer-random-string

# Must match dashboard WA_ENGINE_INTERNAL_SECRET
INTERNAL_OTP_SECRET=

# BD SMS Gateway credentials (for OTP)
SMS_GATEWAY_URL=
SMS_GATEWAY_KEY=
SMS_GATEWAY_SENDER=KontroAPI

# NaafiPay (billing)
NAAFIPAY_API_KEY=pg_live_09de01ce6ad7e95b9fc1293b53a01ef441cfc750266f1440
NAAFIPAY_WEBHOOK_SECRET=whsec_370ce42032b5dea4e6bfd39f98578d0287dbd96c69917d935df297e268a25a62
NAAFIPAY_API_BASE=https://naafipay.com
NAAFIPAY_CHECKOUT_SUCCESS_URL=https://kontroapi.com/dashboard/settings/billing?status=success
NAAFIPAY_CHECKOUT_CANCEL_URL=https://kontroapi.com/dashboard/settings/billing?status=cancelled
NAAFIPAY_WEBHOOK_URL=https://kontroapi.com/api/webhooks/naafipay

# AES-256-GCM key for encrypting webhook secrets at rest (32 bytes hex)
WEBHOOK_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

WORKER_CONCURRENCY=5
MSG_DELAY_MS=1200
