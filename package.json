{
  "name": "kontroapi-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "KontroAPI — self-hostable WhatsApp Business API gateway (monorepo)",
  "license": "AGPL-3.0",
  "author": "KontroAPI <team@kontroapi.com>",
  "homepage": "https://kontroapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/fahimuntasin/kontroapi.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "kontroapi start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "init": "kontroapi init",
    "setup": "npm run build && kontroapi init -y"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "next-themes": "^0.4.6"
  },
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
